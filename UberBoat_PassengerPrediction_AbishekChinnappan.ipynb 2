        "# Step 5: Visualize Passenger Trends (AM vs PM Analysis)\n",
        "# Here, I want to explore how passenger demand differs in the morning vs evening.\n",
        "# This can reveal peak patterns for operations and planning.\n",
        "\n",
        "# First, I’ll calculate the hourly average of passengers.\n",
        "hourly_avg = df_merged.dropna(subset=['passenger_on_board']) \\\n",
        "    .groupby('hour')['passenger_on_board'].mean().reset_index()\n",
        "\n",
        "# Create AM/PM labels to make the x-axis easier to understand\n",
        "hourly_avg['hour_label'] = hourly_avg['hour'].apply(lambda x: f\"{x % 12 or 12} {'AM' if x < 12 else 'PM'}\")\n",
        "\n",
        "# Color code bars for AM (light blue) and PM (midnight blue)\n",
        "hourly_avg['bar_color'] = hourly_avg['hour'].apply(lambda x: 'lightblue' if x < 12 else 'midnightblue')\n",
        "\n",
        "# Now I’ll build a clean and styled bar chart\n",
        "fig = px.bar(\n",
        "    hourly_avg,\n",
        "    x='hour_label',\n",
        "    y='passenger_on_board',\n",
        "    text=hourly_avg['passenger_on_board'].round(1),\n",
        "    labels={'hour_label': 'Time of Day (AM/PM)', 'passenger_on_board': 'Average Passengers'},\n",
        "    title='Average Passengers per Hour (AM vs PM)',\n",
        "    template='simple_white'\n",
        ")\n",
        "\n",
        "# Apply the color scheme and format labels\n",
        "fig.update_traces(\n",
        "    marker_color=hourly_avg['bar_color'],\n",
        "    textposition='outside',\n",
        "    textfont_size=12\n",
        ")\n",
        "\n",
        "# Highlight the peak hour with annotation\n",
        "peak = hourly_avg.loc[hourly_avg['passenger_on_board'].idxmax()]\n",
        "fig.add_annotation(\n",
        "    x=peak['hour_label'],\n",
        "    y=peak['passenger_on_board'],\n",
        "    text=f\"Peak: {peak['hour_label']}<br>{peak['passenger_on_board']:.1f} passengers\",\n",
        "    showarrow=True,\n",
        "    arrowhead=1,\n",
        "    ax=0,\n",
        "    ay=-60,\n",
        "    font=dict(size=13, color=\"black\"),\n",
        "    bgcolor=\"lightyellow\",\n",
        "    bordercolor=\"black\"\n",
        ")\n",
        "\n",
        "# Add a vertical line for Noon to split AM and PM visually\n",
        "fig.add_vline(\n",
        "    x=11.5,\n",
        "    line_dash=\"dash\",\n",
        "    line_color=\"gray\",\n",
        "    annotation_text=\"Noon\",\n",
        "    annotation_position=\"top right\",\n",
        "    line_width=1.5\n",
        ")\n",
        "\n",
        "# Final layout tweaks for clean and centered formatting\n",
        "fig.update_layout(\n",
        "    height=500,\n",
        "    width=900,\n",
        "    title_x=0.5,\n",
        "    title_font=dict(size=20),\n",
        "    font=dict(size=14),\n",
        "    xaxis_title_font=dict(size=16),\n",
        "    yaxis_title_font=dict(size=16),\n",
        "    xaxis_title_standoff=10,\n",
        "    yaxis_title_standoff=10,\n",
        "    xaxis=dict(\n",
        "        showline=True, linewidth=1.2, linecolor='black', showgrid=False\n",
        "    ),\n",
        "    yaxis=dict(\n",
        "        showline=True, linewidth=1.2, linecolor='black', showgrid=True, gridcolor='lightgrey'\n",
        "    ),\n",
        "    plot_bgcolor='white'\n",
        ")\n",
        "\n",
        "fig.show()\n"
      ],
