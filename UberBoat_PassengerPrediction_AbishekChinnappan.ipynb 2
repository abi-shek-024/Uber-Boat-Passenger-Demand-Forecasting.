        "# Step 17: Interactive Passenger Demand UI\n",
        "\n",
        "# Load the final saved model\n",
        "final_model = joblib.load(\"final_model.pkl\")\n",
        "\n",
        "# Route map for start and end pier encoding\n",
        "route_options = {\n",
        "    'Route 1: Pier 1 to Pier 5': (1, 5),\n",
        "    'Route 2: Pier 3 to Pier 10': (3, 10),\n",
        "    'Route 3: Pier 8 to Pier 11': (8, 11),\n",
        "    'Route 4: Pier 2 to Pier 17': (2, 17),\n",
        "    'Route 5: Pier 4 to Pier 20': (4, 20),\n",
        "    'Route 6: Pier 7 to Pier 13': (7, 13)\n",
        "}\n",
        "\n",
        "# Time selection dropdown with readable AM/PM format\n",
        "hour_dropdown = widgets.Dropdown(\n",
        "    options=[\n",
        "        ('12:00 AM', 0), ('01:00 AM', 1), ('02:00 AM', 2), ('03:00 AM', 3),\n",
        "        ('04:00 AM', 4), ('05:00 AM', 5), ('06:00 AM', 6), ('07:00 AM', 7),\n",
        "        ('08:00 AM', 8), ('09:00 AM', 9), ('10:00 AM', 10), ('11:00 AM', 11),\n",
        "        ('12:00 PM', 12), ('01:00 PM', 13), ('02:00 PM', 14), ('03:00 PM', 15),\n",
        "        ('04:00 PM', 16), ('05:00 PM', 17), ('06:00 PM', 18), ('07:00 PM', 19),\n",
        "        ('08:00 PM', 20), ('09:00 PM', 21), ('10:00 PM', 22), ('11:00 PM', 23)\n",
        "    ],\n",
        "    description='Time of Departure:',\n",
        "    style={'description_width': 'initial'},\n",
        "    layout=widgets.Layout(width='90%')\n",
        ")\n",
        "\n",
        "# Peak toggle\n",
        "is_peak_toggle = widgets.ToggleButtons(\n",
        "    options=[('Yes, Peak Hour', 1), ('No, Off-Peak', 0)],\n",
        "    description='Is this during a peak hour?',\n",
        "    style={'description_width': 'initial'},\n",
        "    layout=widgets.Layout(width='90%')\n",
        ")\n",
        "\n",
        "# Ferry route selector\n",
        "route_dropdown = widgets.Dropdown(\n",
        "    options=list(route_options.keys()),\n",
        "    description='Select your ferry route:',\n",
        "    style={'description_width': 'initial'},\n",
        "    layout=widgets.Layout(width='90%')\n",
        ")\n",
        "\n",
        "# Weather condition selector\n",
        "weather_dropdown = widgets.Dropdown(\n",
        "    options=['Clear', 'Clouds', 'Rain'],\n",
        "    description='Weather Condition:',\n",
        "    style={'description_width': 'initial'},\n",
        "    layout=widgets.Layout(width='90%')\n",
        ")\n",
        "\n",
        "# Temperature slider\n",
        "temp_slider = widgets.FloatSlider(\n",
        "    description='Outside Temperature (°C):',\n",
        "    min=-5.0, max=40.0, value=18.0, step=0.1,\n",
        "    style={'description_width': 'initial'},\n",
        "    layout=widgets.Layout(width='90%')\n",
        ")\n",
        "\n",
        "# Predict button\n",
        "predict_button = widgets.Button(\n",
        "    description='Predict Uber Boat Passenger Count',\n",
        "    button_style='primary',\n",
        "    layout=widgets.Layout(width='60%', margin='20px 0px 0px 0px')\n",
        ")\n",
        "\n",
        "# Output panel\n",
        "output = widgets.Output(layout={\n",
        "    'border': '1px solid lightgray',\n",
        "    'padding': '15px',\n",
        "    'margin': '20px 0',\n",
        "    'width': '100%'\n",
        "})\n",
        "\n",
        "# Assembled layout\n",
        "form = widgets.VBox([\n",
        "    widgets.HTML('<h2 style=\"text-align:center;\">Uber Boat Demand Predictor</h2>'),\n",
        "    widgets.HTML('<p style=\"text-align:center;\">Use this tool to estimate expected demand for a selected Uber Boat journey.</p>'),\n",
        "    hour_dropdown,\n",
        "    is_peak_toggle,\n",
        "    route_dropdown,\n",
        "    weather_dropdown,\n",
        "    temp_slider,\n",
        "    predict_button,\n",
        "    output\n",
        "], layout=widgets.Layout(\n",
        "    width='80%',\n",
        "    align_items='center',\n",
        "    border='1px solid #ccc',\n",
        "    padding='25px',\n",
        "    margin='25px auto'\n",
        "))\n",
        "\n",
        "# Weather encoding\n",
        "weather_map = {'Clear': 0, 'Clouds': 1, 'Rain': 2}\n",
        "\n",
        "# Define prediction logic\n",
        "def predict_passengers(button):\n",
        "    with output:\n",
        "        clear_output()\n",
        "        hour = hour_dropdown.value\n",
        "        is_peak = is_peak_toggle.value\n",
        "        start_pier, end_pier = route_options[route_dropdown.value]\n",
        "        weather_encoded = weather_map[weather_dropdown.value]\n",
        "        temp = temp_slider.value\n",
        "        input_features = np.array([[hour, is_peak, start_pier, end_pier, weather_encoded, temp]])\n",
        "        prediction = final_model.predict(input_features)[0]\n",
        "        display(Markdown(f\"**Prediction:** We estimate approximately **{prediction:.1f}** passengers onboard.\"))\n",
        "\n",
        "# Link to button\n",
        "predict_button.on_click(predict_passengers)\n",
        "\n",
        "# Display the UI\n",
        "display(form)"
      ],
