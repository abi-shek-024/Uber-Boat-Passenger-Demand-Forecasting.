        "# Step 4: Merge the Datasets and Engineer Final Features\n",
        "# Now I want to bring the weather info into the passenger dataset.\n",
        "# I’ll merge both datasets on 'merge_hour', which represents the departure hour of the ferry.\n",
        "df_merged = pd.merge(passenger_df, weather_df, on='merge_hour', how='left')\n",
        "\n",
        "# After merging, I’ll select only the columns I care about for modeling.\n",
        "df_model = df_merged[['hour', 'is_weekend', 'start_pier', 'end_pier', 'weather_main', 'temp', 'passenger_on_board']].copy()\n",
        "\n",
        "# I’ll encode the categorical variables. First, let’s encode the weather type.\n",
        "df_model['weather_encoded'] = LabelEncoder().fit_transform(df_model['weather_main'])\n",
        "\n",
        "# Now I’ll also encode the pier IDs to treat them as category codes (no need for one-hot encoding here)\n",
        "df_model['start_pier_encoded'] = LabelEncoder().fit_transform(df_model['start_pier'])\n",
        "df_model['end_pier_encoded'] = LabelEncoder().fit_transform(df_model['end_pier'])\n",
        "\n",
        "# Then I’ll drop the original categorical columns that have been encoded\n",
        "df_model.drop(['weather_main', 'start_pier', 'end_pier'], axis=1, inplace=True)\n",
        "\n",
        "# Finally, I’ll drop any rows with missing values to clean things up before modeling\n",
        "df_model.dropna(inplace=True)\n",
        "\n",
        "# Let’s take a quick look at the final feature set\n",
        "display(df_model.head())\n"
