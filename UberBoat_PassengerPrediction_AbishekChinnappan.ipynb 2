        "# Extract actual model from pipeline\n",
        "final_model = best_lgb.named_steps['model']\n",
        "\n",
        "# Use SHAP's TreeExplainer, which is designed for tree-based models\n",
        "explainer = shap.TreeExplainer(final_model)\n",
        "shap_values = explainer.shap_values(X_train)\n",
        "\n",
        "# Compute mean SHAP values\n",
        "mean_shap = np.abs(shap_values).mean(axis=0)\n",
        "shap_df = pd.DataFrame({\n",
        "    'Feature': X_train.columns,\n",
        "    'Mean_SHAP': mean_shap\n",
        "}).sort_values(by='Mean_SHAP', ascending=False).head(6)\n",
        "\n",
        "# Rename features for better clarity in visualization\n",
        "shap_df['Readable Feature'] = shap_df['Feature'].replace({\n",
        "    'hour': 'Hour of Day',\n",
