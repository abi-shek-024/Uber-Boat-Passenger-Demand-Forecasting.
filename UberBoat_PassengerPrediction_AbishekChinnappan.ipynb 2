        "# Step 3: Clean and Prepare the Data\n",
        "# Now that I’ve seen the structure, I’ll check for missing values and data types\n",
        "# so I can clean and convert columns as needed before merging and modeling.\n",
        "\n",
        "print(\"\\nMissing values in passenger data:\")\n",
        "display(passenger_df.isnull().sum())\n",
        "\n",
        "print(\"\\nMissing values in weather data:\")\n",
        "display(weather_df.isnull().sum())\n",
        "\n",
        "# I want to convert any relevant date/time columns so I can extract features from them.\n",
        "# For the passenger dataset, I’ll convert the 'departure_datetime' column to datetime format.\n",
        "passenger_df['departure_datetime'] = pd.to_datetime(passenger_df['departure_datetime'])\n",
        "\n",
        "# From the departure time, I’ll extract the hour of day.\n",
        "passenger_df['hour'] = passenger_df['departure_datetime'].dt.hour\n",
        "\n",
        "# I’ll also mark whether it’s a weekend (Saturday=5 or Sunday=6).\n",
        "passenger_df['day_of_week'] = passenger_df['departure_datetime'].dt.dayofweek\n",
        "passenger_df['is_weekend'] = passenger_df['day_of_week'] >= 5\n",
        "\n",
        "# Now I’ll do the same for the weather dataset — parse datetime from 'dt_iso'.\n",
        "# I noticed that the strings in 'dt_iso' end with timezone info like ' +0000 UTC', so I’ll strip that part safely.\n",
        "# Then I'll let pandas auto-parse the remaining consistent format without manually specifying it.\n",
        "weather_df['datetime'] = pd.to_datetime(weather_df['dt_iso'].str.replace(' \\+0000 UTC', '', regex=True))\n",
        "\n",
        "# I’ll round both datetime columns to the nearest hour for merging.\n",
        "passenger_df['merge_hour'] = passenger_df['departure_datetime'].dt.floor('h')\n",
        "weather_df['merge_hour'] = weather_df['datetime'].dt.floor('h')\n"
